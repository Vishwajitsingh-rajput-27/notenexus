# ============================================================
# NoteNexus — Backend Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# ── DATABASE ──────────────────────────────────────────────
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/notenexus

# ── AUTH ──────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_this_to_something_random
JWT_EXPIRE=7d

# ── AI SERVICES ───────────────────────────────────────────
GROQ_API_KEY=gsk_your_groq_api_key
GEMINI_API_KEY=your_gemini_api_key

# ── VECTOR DB (Pinecone) ──────────────────────────────────
# Index MUST be 768 dimensions, cosine metric, serverless
PINECONE_API_KEY=your_pinecone_api_key
PINECONE_INDEX_NAME=notenexus

# ── FILE STORAGE (Cloudinary) ─────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ── WHATSAPP BOT (Twilio) ─────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# ── EMAIL REMINDERS (Gmail / SMTP) ────────────────────────
# For Gmail: use an App Password (not your real password)
# https://myaccount.google.com/apppasswords
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password

#───────SUPADATA API (SUPADATA) ───────────────────────────────────────
# Optional YouTube transcript fallback (supadata.ai) 
SUPADATA_API_KEY=sd_0****************6ae2

# ── DEPLOYMENT ────────────────────────────────────────────
# Leave these as-is for local dev; set to real URLs in production
BACKEND_URL=http://localhost:5000
FRONTEND_URL=http://localhost:3000
NODE_ENV=development
PORT=5000

# ── DEMO MODE (optional) ──────────────────────────────────
DEMO_EMAIL=demo@notenexus.ai
DEMO_PASSWORD=Demo@NoteNexus2024!
